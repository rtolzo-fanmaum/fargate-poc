{
  "family": "subtitle-generator-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::533267392768:role/subtitle-generator-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::533267392768:role/subtitle-generator-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "subtitle-generator-container",
      "image": "533267392768.dkr.ecr.ap-northeast-2.amazonaws.com/subtitle-generator:latest",
      "essential": true,
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "ap-northeast-2"
        },
        {
          "name": "S3_BUCKET",
          "value": "rtolzo-winspec"
        }
      ],
      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:533267392768:secret:winspec-subtitle-generator-open-api-key-HZTsOq"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/subtitle-generator-worker",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
